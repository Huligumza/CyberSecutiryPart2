<Window x:Class="POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity AI Assistant" Height="650" Width="500" 
        WindowStartupLocation="CenterScreen" Background="#121212">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="AsciiArt" Grid.Row="0" FontFamily="Consolas" Foreground="#FF5252" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" FontSize="10"/>

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="10" Padding="10" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ChatHistory" Foreground="#E0E0E0" TextWrapping="Wrap" 
                           FontSize="14" FontFamily="Segoe UI" LineHeight="20"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="5" Background="#2C2C2C" Margin="0,0,5,0">
                <TextBox x:Name="UserInput" Height="45" FontSize="16" Padding="10,10,0,0" 
                         Background="Transparent" Foreground="White" BorderThickness="0" 
                         VerticalContentAlignment="Center"/>
            </Border>

            <Border Grid.Column="1" CornerRadius="5" Background="#BB86FC">
                <Button x:Name="BtnSend" Content="Send" Click="BtnSend_Click" 
                        Width="80" Height="45" Background="Transparent" Foreground="Black" 
                        FontWeight="Bold" BorderThickness="0"/>
            </Border>
        </Grid>
    </Grid>
</Window>